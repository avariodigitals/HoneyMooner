# Frontend
VITE_WP_BASE_URL=https://cms.thehoneymoonertravel.com/wp-json
VITE_WP_SYNC_ENABLED=true
VITE_WP_PAYMENTS_ENABLED=true
# Optional: custom WordPress endpoint for Woo gift products.
# Leave unset to use WordPress package CPT data as primary source.
# VITE_WP_GIFT_PRODUCTS_ENDPOINT=/custom/v1/gift-products

# Optional: browser fallback to Woo Store API (may require CORS allowlist in local dev).
VITE_WP_ENABLE_WC_STORE_FALLBACK=false

# WooCommerce sync script (server-side usage only)
WOO_BASE_URL=https://cms.thehoneymoonertravel.com/wp-json
WOO_CONSUMER_KEY=ck_replace_me
WOO_CONSUMER_SECRET=cs_replace_me

# Optional safety mode for sync script
DRY_RUN=true
